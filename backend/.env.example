# Database connection (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech:5432/portfolio_db?sslmode=require

# Server Configuration
PORT=8080

# Allowed Origins (comma-separated, for CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# JWT Configuration
JWT_SECRET=change-this-to-a-strong-random-secret-in-production

# Admin credentials (for initial login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# Email Configuration (for contact form notifications)
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
CONTACT_RECEIVER_EMAIL=your-email@example.com

# AI / Playground Configuration
# Groq API key for the Playground chatbot (optional - falls back to keyword responses if not set)
# Get your free API key at https://console.groq.com
GROQ_API_KEY=
# Groq model to use (default: llama3-8b-8192)
# Available models: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it
GROQ_MODEL=llama3-8b-8192

# Resume Configuration
# Public URL to your resume PDF file (used by the Download Resume button)
RESUME_URL=https://your-domain.com/resume.pdf
