# Database connection (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech:5432/portfolio_db?sslmode=require

# Server Configuration
PORT=8080

# Allowed Origins (comma-separated, for CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# JWT Configuration
JWT_SECRET=change-this-to-a-strong-random-secret-in-production

# Admin credentials (for initial login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# Email Configuration (for contact form notifications)
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
CONTACT_RECEIVER_EMAIL=your-email@example.com
